-- ============================================================
-- 4. ACTIVITY SESSIONS
-- One row per planned occurrence of an activity on a specific date.
-- Not all activity types require a session row (e.g. Sunday service
-- attendance can be recorded without one).
-- expected_count is nullable — can be filled manually when
-- registration is not tracked, or derived from activity_registrations.
-- cgsl_material_id links to the chapter covered in a CGSL session.
-- ============================================================
CREATE TABLE activity_sessions (
    id               SERIAL PRIMARY KEY,
    activity_type_id INTEGER         NOT NULL,
    session_date     DATE            NOT NULL,
    expected_count   INTEGER         CHECK (expected_count IS NULL OR expected_count >= 0),
    notes            TEXT,
    cgsl_material_id INTEGER,
    created_at       TIMESTAMP       NOT NULL DEFAULT NOW(),
    created_by       INTEGER,

    CONSTRAINT fk_session_activity
        FOREIGN KEY (activity_type_id) REFERENCES activity_types(id)
        ON DELETE RESTRICT,

    CONSTRAINT fk_session_cgsl_material
        FOREIGN KEY (cgsl_material_id) REFERENCES cgsl_materials(id)
        ON DELETE SET NULL,

    CONSTRAINT uq_session
        UNIQUE (activity_type_id, session_date)
);


-- ============================================================
-- 5. ACTIVITY REGISTRATIONS
-- Records which members have registered for a specific session.
-- Used for planned activities (CGSL, special events) where
-- registration is tracked in advance.
-- Enables: registered vs attended reporting, no-show tracking.
-- ============================================================
CREATE TABLE activity_registrations (
    id            SERIAL PRIMARY KEY,
    session_id    INTEGER         NOT NULL,
    member_id     INTEGER         NOT NULL,
    registered_at TIMESTAMP       NOT NULL DEFAULT NOW(),
    notes         TEXT,
    created_at    TIMESTAMP       NOT NULL DEFAULT NOW(),
    created_by    INTEGER,

    CONSTRAINT uq_activity_registration
        UNIQUE (session_id, member_id),

    CONSTRAINT fk_ar_session
        FOREIGN KEY (session_id) REFERENCES activity_sessions(id)
        ON DELETE RESTRICT,

    CONSTRAINT fk_ar_member
        FOREIGN KEY (member_id) REFERENCES members(id)
        ON DELETE RESTRICT
);


-- ============================================================
-- 6. ATTENDANCE
-- Records each member's actual presence at any activity.
-- For Sunday service: recorded directly with no session row needed.
-- For CGSL / events: joins to activity_sessions via
--     activity_type_id = a.activity_type_id
--     AND session_date = DATE(a.timestamp)
-- ============================================================
CREATE TABLE attendance (
    id               SERIAL PRIMARY KEY,
    member_id        INTEGER         NOT NULL,
    activity_type_id INTEGER         NOT NULL,
    timestamp        TIMESTAMP       NOT NULL DEFAULT NOW(),
    created_at       TIMESTAMP       NOT NULL DEFAULT NOW(),

    CONSTRAINT fk_attendance_member
        FOREIGN KEY (member_id) REFERENCES members(id)
        ON DELETE RESTRICT,

    CONSTRAINT fk_attendance_activity
        FOREIGN KEY (activity_type_id) REFERENCES activity_types(id)
        ON DELETE RESTRICT
);

-- Uniqueness: one attendance record per member per activity per day
CREATE UNIQUE INDEX uq_attendance
    ON attendance (member_id, activity_type_id, DATE(timestamp));


