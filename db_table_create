-- ============================================================
-- 9. CGSL
-- One row per CGSL batch (e.g. "Come Zhongli Batch 1 2026").
-- Auto-links to an activity_type on creation (same name).
-- cgsl_category + batch_number + year give structured querying;
-- name is the full free-form display label.
-- ============================================================
CREATE TABLE cgsl (
    id               SERIAL PRIMARY KEY,
    name             VARCHAR(200)    NOT NULL UNIQUE,
    cgsl_category    VARCHAR(10)     NOT NULL
                         CHECK (cgsl_category IN ('come', 'grow', 'lead', 'serve')),
    batch_number     INTEGER         NOT NULL,
    year             INTEGER         NOT NULL,
    activity_type_id INTEGER         UNIQUE,
    is_active        BOOLEAN         NOT NULL DEFAULT true,
    created_at       TIMESTAMP       NOT NULL DEFAULT NOW(),

    CONSTRAINT fk_cgsl_activity_type
        FOREIGN KEY (activity_type_id) REFERENCES activity_types(id)
        ON DELETE SET NULL
);


-- ============================================================
-- 10. CGSL MEMBERS (students roster)
-- One row per student per batch. A member can only be a student
-- once per batch (separate table for teachers below).
-- ============================================================
CREATE TABLE cgsl_members (
    id          SERIAL PRIMARY KEY,
    cgsl_id     INTEGER         NOT NULL,
    member_id   INTEGER         NOT NULL,
    joined_date DATE            NOT NULL DEFAULT CURRENT_DATE,
    left_date   DATE,
    is_active   BOOLEAN         NOT NULL DEFAULT true,
    created_at  TIMESTAMP       NOT NULL DEFAULT NOW(),

    CONSTRAINT uq_cgsl_member
        UNIQUE (cgsl_id, member_id),

    CONSTRAINT fk_cgsl_members_cgsl
        FOREIGN KEY (cgsl_id) REFERENCES cgsl(id)
        ON DELETE RESTRICT,

    CONSTRAINT fk_cgsl_members_member
        FOREIGN KEY (member_id) REFERENCES members(id)
        ON DELETE RESTRICT
);


-- ============================================================
-- 11. CGSL TEACHERS
